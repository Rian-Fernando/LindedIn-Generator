ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Supabase production storage
SUPABASE_URL=
SUPABASE_KEY=

# LLM provider. Configure OpenAI fully. No hardcoded generation fallback is used.
OPENAI_API_KEY=
OPENAI_MODEL=

# Live source connectors
NEWS_API_KEY=
NEWS_API_QUERY=("fintech automation" OR "investment banking automation" OR "banking AI" OR "deal workflow software")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=linkedin-post-generator/1.0

# Optional JSON arrays.
# Example:
# RSS_FEEDS_JSON=[{"name":"Finextra","url":"https://www.finextra.com/rss/headlines.aspx","source_type":"rss"},{"name":"PYMNTS","url":"https://www.pymnts.com/feed/","source_type":"rss"}]
RSS_FEEDS_JSON=

# Example:
# REDDIT_SUBREDDITS=fintech,banking,investing,startups,MachineLearning
REDDIT_SUBREDDITS=fintech,banking,investing,startups,MachineLearning

# Optional for local-only development. Leave false for real deployments.
ALLOW_LOCAL_DEV_FALLBACK=false
